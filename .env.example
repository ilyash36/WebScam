# Django Settings
# Канонический порядок чтения документации для AI: шаг 7 — см. AI_CONTEXT.md §1
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Для разработки — SQLite (настройки БД ниже не обязательны).
# Для production / Docker — PostgreSQL:
DB_NAME=autoservice_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# OCR СТС — Yandex Vision API + локальный парсер
YANDEX_VISION_API_KEY=
YANDEX_FOLDER_ID=

# ---------------------------------------------------------------------------
# Почта (письма подтверждения регистрации и код входа)
# ---------------------------------------------------------------------------
# Production / Docker: обязательно задать SMTP, иначе send_mail падает.
# DEFAULT_FROM_EMAIL часто должен совпадать с EMAIL_HOST_USER (Gmail, Mail.ru и т.д.).
#
# Публичный URL сайта для ссылки «Подтвердить email» в письме (с https и доменом).
# Обязательно за nginx / Cloudflare / Docker без проброса Host:
SITE_URL=https://example.com

DEFAULT_FROM_EMAIL=noreply@example.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Для порта 465: EMAIL_USE_SSL=True, EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=15

# Локальная разработка (manage.py runserver):
# По умолчанию письма НЕ уходят в интернет — только в консоль терминала.
# Чтобы тестировать реальную доставку, раскомментируйте:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# и заполните EMAIL_* выше.
